# Supabase project credentials — Project Settings > API in the Supabase dashboard.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# The origin this app is served from. Used to build redirect URLs for Supabase
# Auth flows (e.g. HR account invitations land on {VITE_SITE_URL}/auth/setup-password).
# Must also be added to Authentication > URL Configuration > Redirect URLs in the
# Supabase dashboard, or Supabase will silently fall back to the Site URL instead.
#
# Development:
VITE_SITE_URL=http://localhost:5173
# Production (set this in your Vercel project's Environment Variables instead):
# VITE_SITE_URL=https://your-app.vercel.app
